    <!-- ── Background modes ──────────────────────────────────────── -->
    <!--
        "audio" keeps the AVAudioEngine input tap running when the screen
        is locked or the app is backgrounded. Without this key iOS suspends
        the process and clap detection stops.
    -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>

    <!-- ── Privacy ───────────────────────────────────────────────── -->
    <!--
        App Store Review requires a clear, honest description.
        All Ages rating: keep language simple and child-friendly.
    -->
    <key>NSMicrophoneUsageDescription</key>
    <string>ClapFinder listens for claps so you can find your phone. The microphone is only used for clap detection and nothing else.</string>

    <!-- ── Tracking (ATT) ───────────────────────────────────────── -->
    <!--
        Required if AppTrackingTransparency framework is linked.
        All Ages copy: plain English, no marketing language.
    -->
    <key>NSUserTrackingUsageDescription</key>
    <string>ClapFinder may show ads to keep the app free. Allow tracking to see ads that are relevant to you.</string>

