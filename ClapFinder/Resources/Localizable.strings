/* ClapFinder — Localizable Strings */

/* MARK: - Privacy / permissions */
/* Note: NSMicrophoneUsageDescription in Info.plist must match the intent here */
"permission.microphone"   = "ClapFinder listens for claps so you can find your phone. The microphone is only used for clap detection and nothing else.";

/* Note: NSUserTrackingUsageDescription in Info.plist must match the intent here */
"permission.tracking"     = "ClapFinder may show ads to keep the app free. Allow tracking to see ads that are relevant to you.";

/* MARK: - Splash screen */
"splash.tagline"          = "Clap your hands — your phone answers! 🐶";
"splash.loading"          = "Loading %d%%…";
/* Required while an App Open Ad request is in flight */
"splash.adDisclaimer"     = "This action can contain ads";

/* MARK: - Home screen */
"home.title"              = "ClapFinder";
"home.subtitle"           = "Clap twice to find your phone";

/* Listening toggle */
"toggle.start"            = "Start listening";
"toggle.stop"             = "Stop listening";

/* Status labels */
"status.idle"             = "Tap the mic to start";
"status.listening"        = "Listening…";
"status.found"            = "Found you! 🎉";

/* Sensitivity control */
"sensitivity.label"       = "Sensitivity";
"sensitivity.low"         = "Low";
"sensitivity.medium"      = "Medium";
"sensitivity.high"        = "High";

/* Animal picker section header */
"animals.header"          = "Choose a sound";

/* Accessibility */
"a11y.toggle.on"          = "Clap detection on";
"a11y.toggle.off"         = "Clap detection off";
"a11y.animal.selected"    = "%@, %@. Selected.";
"a11y.animal.unselected"  = "%@, %@. Not selected.";
